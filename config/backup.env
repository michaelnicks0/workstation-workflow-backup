# WORKSTATION1 high-frequency workflow backup configuration.
# This file intentionally contains no secrets.

NAS_HOST=10.99.98.221
NAS_USER=root
NAS_SSH_KEY=/home/mnicks/.ssh/id_ed25519
NAS_DATASET=volume1/workstation1-workflow-backup
NAS_PATH=/mnt/volume1/workstation1-workflow-backup
NAS_UNC='\\10.99.98.221\workstation1-workflow-backup'
SMB_SHARE_NAME=workstation1-workflow-backup
WINDOWS_USER=mnicks
WSL_DISTRO=Ubuntu-22.04
LOCAL_STATE=$HOME/.local/state/workstation-workflow-backup
PS_EXE=/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe
RSYNC_USE_SUDO=1

# Fail closed before/after backup writes if this dataset starts running away.
# These guards are intentionally non-destructive: they stop the backup and rely on
# the existing OnFailure alert path instead of deleting snapshots or payloads.
NAS_GROWTH_GUARD_ENABLED=1
NAS_GROWTH_GUARD_ENFORCE=1
NAS_DATASET_MAX_USED_BYTES=1099511627776       # 1 TiB total for current + snapshots
NAS_DATASET_MAX_SNAPSHOT_BYTES=274877906944   # 256 GiB snapshot-held blocks
NAS_DATASET_MIN_AVAILABLE_BYTES=1099511627776 # leave at least 1 TiB free on volume1
NAS_DATASET_MAX_SNAPSHOT_COUNT=500

# Bounded long-retention snapshot counts used by nas-provision.sh cron jobs.
NAS_WEEKLY_SNAPSHOT_RETAIN=8
NAS_MONTHLY_SNAPSHOT_RETAIN=12
