# Example WORKSTATION1 high-frequency workflow backup configuration.
# Copy to config/backup.env and fill in local values. config/backup.env is ignored
# because it contains machine-local topology and key paths.

NAS_HOST=truenas.example.lan
NAS_USER=ws1backup
NAS_RUNTIME_USER=ws1backup
NAS_ADMIN_USER=root
NAS_SSH_KEY=$HOME/.ssh/workstation_workflow_backup_ws1backup_ed25519
NAS_ADMIN_SSH_KEY=$HOME/.ssh/id_ed25519
NAS_RUNTIME_PUBLIC_KEY_FILE=$HOME/.ssh/workstation_workflow_backup_ws1backup_ed25519.pub
NAS_KNOWN_HOSTS=$HOME/.ssh/workstation-workflow-backup_known_hosts
NAS_HOST_KEY_ALIAS=truenas-ws1-wf
NAS_STRICT_HOST_KEY_CHECKING=yes
NAS_REMOTE_RSYNC=/usr/local/bin/rsync
NAS_DATASET=pool/workstation/workflow
NAS_AVAILABLE_DATASET=pool
NAS_PATH=/mnt/pool/workstation/workflow
NAS_UNC='\\truenas.example.lan\workflow-backup'
SMB_SHARE_NAME=workflow-backup
WINDOWS_USER=example-user
WSL_DISTRO=Ubuntu-22.04
LOCAL_STATE=$HOME/.local/state/workstation-workflow-backup
PS_EXE=/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe
RSYNC_USE_SUDO=1
RSYNC_PRESERVE_OWNER_GROUP=0

# Fail closed before/after backup writes if this dataset starts running away.
# These guards are intentionally non-destructive: they stop the backup and rely on
# the existing OnFailure alert path instead of deleting snapshots or payloads.
NAS_GROWTH_GUARD_ENABLED=1
NAS_GROWTH_GUARD_ENFORCE=1
NAS_GROWTH_GUARD_REMOTE_HELPER=/usr/local/sbin/ws1-wf-growth-guard
NAS_DATASET_MAX_USED_BYTES=2199023255552       # 2 TiB total for current + snapshots
NAS_DATASET_MAX_SNAPSHOT_BYTES=1099511627776  # 1 TiB snapshot-held blocks
NAS_DATASET_MIN_AVAILABLE_BYTES=2199023255552 # leave at least 2 TiB free on the pool/dataset
NAS_DATASET_MAX_SNAPSHOT_COUNT=5000
NAS_DATASET_REFQUOTA_BYTES=2199023255552      # hard cap for live current-tree writes, including SMB robocopy

# Restore verification checksums. "critical" hashes manifests and SQLite snapshots
# every run; use "full" only for deliberate full-tree verification windows.
NAS_INTEGRITY_MANIFEST_ENABLED=1
NAS_INTEGRITY_REMOTE_HELPER=/usr/local/sbin/ws1-wf-integrity-manifest
NAS_INTEGRITY_SCOPE=critical
NAS_INTEGRITY_MAX_FILE_BYTES=0

# Local operational retention.
LOCAL_LOG_RETENTION_DAYS=90
LEDGER_STRICT_FINAL_EVENTS=1

# TrueNAS periodic snapshot lifetimes. Retention is managed by TrueNAS/ZFS
# snapshot tasks only; nas-provision.sh disables retired repo-owned cron helpers.
NAS_HOURLY_SNAPSHOT_LIFETIME_DAYS=2
NAS_DAILY_SNAPSHOT_LIFETIME_WEEKS=2
NAS_WEEKLY_SNAPSHOT_LIFETIME_WEEKS=8
NAS_MONTHLY_SNAPSHOT_LIFETIME_YEARS=1
