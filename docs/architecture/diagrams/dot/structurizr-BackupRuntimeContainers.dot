digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Container View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">C2: hourly runtime path for guarded WSL/Windows sync, consistent SQLite snapshots, run history, and failure notification.</font>>

  22 [id=22,shape=cylinder, label=<<font point-size="34">WSL Workflow Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Workflow-critical WSL paths:<br />~/repos, ~/.hermes, ~/.ssh,<br />systemd user config,<br />lifelog/browser-memory data,<br />and optional brain-code tree.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  23 [id=23,shape=cylinder, label=<<font point-size="34">Windows Workflow<br />Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Selected Windows user-profile<br />artifacts: Desktop, Documents,<br />Downloads, Windows<br />.ssh/.wslconfig, Terminal/VS<br />Code/PowerShell config, Chrome<br />profile metadata, and Startup<br />entries.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  24 [id=24,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Encrypted TrueNAS dataset<br />v1/ws1/wf with current mirror<br />tree, manifests, SMB share<br />ws1-wf, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  25 [id=25,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">root@10.99.98.221 management<br />surface used for ZFS<br />properties, snapshot tasks,<br />SMB share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  26 [id=26,shape=cylinder, label=<<font point-size="34">Hermes Bot<br />Environment File</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local ~/.hermes/.env values<br />that supply Telegram bot<br />token/chat settings to the<br />failure notifier; contents are<br />not stored in this repo.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  27 [id=27,shape=rect, label=<<font point-size="34">Telegram Bot API</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External API used only for<br />backup failure notifications.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    15 [id=15,shape=hexagon, label=<<font point-size="34">SQLite Snapshotter</font><br /><font point-size="19">[Container: Python 3, sqlite3]</font><br /><br /><font point-size="24">Creates application-consistent<br />copies of Hermes, lifelog,<br />browser-memory, and related<br />SQLite databases using sqlite3<br />backup API; can quick_check<br />copies.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    16 [id=16,shape=hexagon, label=<<font point-size="34">Windows Critical Sync<br />Helper</font><br /><font point-size="19">[Container: PowerShell + robocopy.exe]</font><br /><br /><font point-size="24">PowerShell script launched<br />from WSL that uses<br />robocopy.exe to mirror<br />selected Windows profile<br />directories/files to the SMB<br />share and writes a Windows<br />sync manifest.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    17 [id=17,shape=hexagon, label=<<font point-size="34">NAS Growth Guard</font><br /><font point-size="19">[Container: Bash + remote Python + zfs CLI]</font><br /><br /><font point-size="24">Read-only ZFS budget check<br />that enforces dataset-used,<br />snapshot-held, free-space, and<br />snapshot-count limits<br />before/after writes.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    20 [id=20,shape=hexagon, label=<<font point-size="34">Failure Notifier</font><br /><font point-size="19">[Container: Bash + Python urllib]</font><br /><br /><font point-size="24">Best-effort Telegram failure<br />alert unit that reads last<br />status/log tail and Hermes bot<br />environment variables; success<br />runs stay silent.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    21 [id=21,shape=cylinder, label=<<font point-size="34">Run Ledger and Local<br />State</font><br /><font point-size="19">[Container: SQLite + JSON + logs on WSL filesystem]</font><br /><br /><font point-size="24">Local status, logs, SQLite run<br />ledger, exported run-history<br />JSON, SQLite snapshot cache,<br />and Windows manifest cache<br />under<br />~/.local/state/workstation-workflow-backup.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
    3 [id=3,shape=rect, label=<<font point-size="34">systemd User Timer<br />and Service</font><br /><font point-size="19">[Container: systemd --user units]</font><br /><br /><font point-size="24">Hourly user-level scheduler<br />and oneshot service that run<br />the backup at minute 45 and<br />route failures to the<br />notifier.</font>>, style=filled, color="#4f46e5", fillcolor="#e0e7ff", fontcolor="#111827"]
    4 [id=4,shape=rect, label=<<font point-size="34">Backup Orchestrator</font><br /><font point-size="19">[Container: Bash]</font><br /><br /><font point-size="24">scripts/workflow-backup.sh<br />coordinates one backup run:<br />locking, logging, pre/post<br />guard checks, WSL rsync,<br />SQLite snapshots, Windows<br />sync, run-ledger updates, and<br />NAS manifest publication.</font>>, style=filled, color="#0284c7", fillcolor="#e0f2fe", fontcolor="#111827"]
  }

  3 -> 4 [id=35, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Starts hourly at :45 and<br />tracks service exit</font><br /><font point-size="19">[systemd --user]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 20 [id=36, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Triggers on nonzero<br />service result</font><br /><font point-size="19">[OnFailure]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 21 [id=37, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes logs,<br />last-run.json, run events,<br />and exported history in</font><br /><font point-size="19">[filesystem + sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 17 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs pre/post budget<br />checks through</font><br /><font point-size="19">[subprocess]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  17 -> 25 [id=39, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads ZFS used, available,<br />usedbysnapshots, and<br />snapshot count from</font><br /><font point-size="19">[SSH + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 15 [id=41, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates consistent SQLite<br />backup copies with</font><br /><font point-size="19">[subprocess]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  15 -> 22 [id=42, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads live SQLite<br />databases from</font><br /><font point-size="19">[sqlite3 backup API]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  15 -> 21 [id=44, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes local SQLite<br />snapshot cache and<br />manifest under</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 22 [id=45, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Mirrors configured WSL<br />source trees from</font><br /><font point-size="19">[sudo rsync]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 24 [id=46, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes current/wsl,<br />wsl-sqlite-snapshots, and<br />_manifests to</font><br /><font point-size="19">[SSH rsync + SSH cat]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 16 [id=48, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Launches Windows sync<br />through</font><br /><font point-size="19">[PowerShell via WSL interop]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  16 -> 23 [id=49, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Mirrors selected Windows<br />artifacts from</font><br /><font point-size="19">[robocopy.exe]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  16 -> 24 [id=51, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes current/windows and<br />Windows manifests to</font><br /><font point-size="19">[SMB \\10.99.98.221\\ws1-wf]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  16 -> 21 [id=52, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Leaves manifest cache for<br />ledger summaries</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 25 [id=53, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates remote manifest<br />directories and relies on<br />NAS SSH access</font><br /><font point-size="19">[SSH]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 20 [id=54, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Exits nonzero so systemd<br />can alert through</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 21 [id=55, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads last status and log<br />tail from</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 26 [id=56, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads Telegram bot<br />token/chat values from</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 27 [id=58, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Sends failure-only<br />notification to</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}