digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Dynamic View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">Failure-only alert path; successful timer runs produce no Telegram message.</font>>

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    24 [id=24,shape=hexagon, label=<<font point-size="34">Failure Notifier</font><br /><font point-size="19">[Container: Bash + Python urllib]</font><br /><br /><font point-size="24">Best-effort Telegram failure<br />alert unit that reads last<br />status/log tail and Hermes bot<br />environment variables; success<br />runs stay silent.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    25 [id=25,shape=cylinder, label=<<font point-size="34">Run Ledger and Local<br />State</font><br /><font point-size="19">[Container: SQLite + JSON + logs on WSL filesystem]</font><br /><br /><font point-size="24">Local status, pruned logs,<br />SQLite run ledger, exported<br />run-history JSON, SQLite<br />snapshot cache, and Windows<br />manifest cache under<br />~/.local/state/workstation-workflow-backup.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
    3 [id=3,shape=rect, label=<<font point-size="34">systemd User Timer<br />and Service</font><br /><font point-size="19">[Container: systemd --user units]</font><br /><br /><font point-size="24">Hourly user-level scheduler<br />and oneshot service that run<br />the backup at minute 45 and<br />route failures to the<br />notifier.</font>>, style=filled, color="#4f46e5", fillcolor="#e0e7ff", fontcolor="#111827"]
    4 [id=4,shape=rect, label=<<font point-size="34">Backup Orchestrator</font><br /><font point-size="19">[Container: Bash]</font><br /><br /><font point-size="24">scripts/workflow-backup.sh<br />coordinates one backup run:<br />locking, log pruning, pre/post<br />guard checks, WSL rsync,<br />SQLite snapshots, Windows<br />sync, strict final ledger<br />updates, NAS manifest<br />publication, and<br />restore-checksum generation.</font>>, style=filled, color="#0284c7", fillcolor="#e0f2fe", fontcolor="#111827"]
  }

  28 [id=28,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured encrypted TrueNAS<br />dataset with current mirror<br />tree, manifests, SMB share,<br />restore checksum manifest,<br />refquota, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  30 [id=30,shape=cylinder, label=<<font point-size="34">Hermes Bot<br />Environment File</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local ~/.hermes/.env values<br />that supply Telegram bot<br />token/chat settings to the<br />failure notifier; contents are<br />not stored in this repo.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  31 [id=31,shape=rect, label=<<font point-size="34">Telegram Bot API</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External API used only for<br />backup failure notifications.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  4 -> 25 [id=41, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">1. Write failed<br />last-run/log/ledger event</font><br /><font point-size="19">[filesystem + sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 28 [id=55, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">2. Best-effort publish<br />failure manifests</font><br /><font point-size="19">[restricted SSH rsync]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  4 -> 3 [id=39, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">3. Exit nonzero</font><br /><font point-size="19">[systemd --user]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 24 [id=40, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">4. Invoke OnFailure<br />notifier</font><br /><font point-size="19">[OnFailure]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  24 -> 25 [id=64, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">5. Read last-run.json and<br />log tail</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  24 -> 30 [id=65, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">6. Load bot token/chat<br />settings</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  24 -> 31 [id=67, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">7. sendMessage backup<br />failure alert</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}