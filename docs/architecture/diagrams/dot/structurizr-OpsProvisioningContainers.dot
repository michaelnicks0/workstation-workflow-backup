digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Container View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">C2: operator-facing provisioning, verification, restore, and NAS-control surfaces.</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Michael</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole operator who installs,<br />verifies, and restores<br />WORKSTATION1 workflow backups.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  28 [id=28,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured encrypted TrueNAS<br />dataset with current mirror<br />tree, manifests, SMB share,<br />restore checksum manifest,<br />refquota, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  29 [id=29,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured admin SSH and<br />middleware surface used for<br />ZFS properties, runtime-user<br />setup, snapshot tasks, SMB<br />share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  32 [id=32,shape=rect, label=<<font point-size="34">Operator Shell and<br />Restore Tools</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local shell, rsync, SSH,<br />Windows Previous Versions, and<br />README/runbook commands used<br />for verification and targeted<br />restores.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    18 [id=18,shape=hexagon, label=<<font point-size="34">NAS Growth Guard</font><br /><font point-size="19">[Container: Bash + NAS sudo helper + zfs CLI]</font><br /><br /><font point-size="24">Read-only NAS-side ZFS budget<br />check that enforces<br />dataset-used, snapshot-held,<br />availability-dataset<br />free-space, and snapshot-count<br />limits before/after writes.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    19 [id=19,shape=hexagon, label=<<font point-size="34">NAS Integrity<br />Manifest Builder</font><br /><font point-size="19">[Container: Python + SHA-256]</font><br /><br /><font point-size="24">NAS-side helper that hashes<br />restore-critical current-tree<br />artifacts and writes<br />_manifests/integrity-manifest.json<br />for snapshot-preserved restore<br />verification.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    20 [id=20,shape=hexagon, label=<<font point-size="34">Restricted NAS<br />Runtime SSH Boundary</font><br /><font point-size="19">[Container: OpenSSH forced command + sudoers + ZFS refquota]</font><br /><br /><font point-size="24">Dedicated runtime NAS<br />user/key, pinned host-key<br />verification, forced-command<br />dispatcher, sudo allowlist,<br />and refquota-backed<br />current-tree write boundary.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    21 [id=21,shape=hexagon, label=<<font point-size="34">NAS Provisioner</font><br /><font point-size="19">[Container: Bash + admin SSH + remote Python + midclt/zfs]</font><br /><br /><font point-size="24">Idempotent provisioning script<br />for the TrueNAS dataset, SMB<br />share, periodic snapshot<br />tasks, refquota, and retired<br />legacy snapshot cron jobs.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    22 [id=22,shape=hexagon, label=<<font point-size="34">NAS Runtime Hardening<br />Installer</font><br /><font point-size="19">[Container: Bash + admin SSH + TrueNAS middleware]</font><br /><br /><font point-size="24">Installs or updates the<br />dedicated runtime user/key,<br />forced-command dispatcher,<br />NAS-side guard/integrity<br />helpers, sudo allowlist,<br />runtime-writable subtrees,<br />host-key pinning config, and<br />dataset refquota.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    23 [id=23,shape=hexagon, label=<<font point-size="34">Backup Verifier</font><br /><font point-size="19">[Container: Bash + systemctl + SSH]</font><br /><br /><font point-size="24">Operational verification<br />script that checks the local<br />timer, last status, run<br />ledger, growth guard, NAS<br />dataset, snapshots, manifests,<br />integrity summary, snapshot<br />tasks, and retired cron jobs.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    25 [id=25,shape=cylinder, label=<<font point-size="34">Run Ledger and Local<br />State</font><br /><font point-size="19">[Container: SQLite + JSON + logs on WSL filesystem]</font><br /><br /><font point-size="24">Local status, pruned logs,<br />SQLite run ledger, exported<br />run-history JSON, SQLite<br />snapshot cache, and Windows<br />manifest cache under<br />~/.local/state/workstation-workflow-backup.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  }

  1 -> 32 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs backup, verification,<br />provisioning, and restore<br />commands from</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 23 [id=36, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs backup health checks<br />through</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 29 [id=37, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Lists snapshots and<br />inspects NAS state through</font><br /><font point-size="19">[admin SSH + zfs/midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 28 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Restores selected files<br />from .zfs/snapshot/current<br />paths</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  18 -> 29 [id=43, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads ZFS used,<br />availability,<br />usedbysnapshots, and<br />snapshot count from</font><br /><font point-size="19">[NAS-side helper + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 28 [id=51, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Allows receiver-mode rsync<br />and mkdir only under<br />current tree</font><br /><font point-size="19">[forced command + rsync]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 18 [id=53, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Allows sudo execution of<br />guard helper only</font><br /><font point-size="19">[forced command + sudo]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  20 -> 19 [id=54, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Allows sudo execution of<br />integrity helper only</font><br /><font point-size="19">[forced command + sudo]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  19 -> 28 [id=62, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Hashes NAS current-tree<br />critical artifacts and<br />writes<br />integrity-manifest.json to</font><br /><font point-size="19">[SHA-256 + filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  21 -> 29 [id=69, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates/updates dataset,<br />SMB share, snapshot tasks,<br />refquota, and disabled<br />retired cron jobs through</font><br /><font point-size="19">[admin SSH + zfs + midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  21 -> 28 [id=70, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Configures mountpoint, SMB<br />share, refquota, and<br />snapshot naming/retention<br />for</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  22 -> 29 [id=71, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates runtime user/key,<br />forced command, sudo<br />allowlist, helper scripts,<br />and pinned host-key<br />boundary through</font><br /><font point-size="19">[admin SSH + middleware]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  22 -> 28 [id=72, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Owns runtime-writable<br />current subtrees and<br />applies refquota for</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  23 -> 25 [id=74, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads local last status<br />and recent run ledger from</font><br /><font point-size="19">[filesystem + sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  23 -> 18 [id=75, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs read-only guard<br />verification through</font><br /><font point-size="19">[subprocess]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  23 -> 29 [id=76, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads dataset, snapshot<br />tasks, and retired cron<br />job state from</font><br /><font point-size="19">[SSH + midclt + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  23 -> 28 [id=77, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Checks required backup<br />paths, status manifests,<br />and integrity manifest in</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}