  5 -> 6 [id=78, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Passes selected run mode<br />to</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  6 -> 7 [id=79, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Initializes log and status<br />paths for</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  6 -> 8 [id=80, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records skipped_lock when<br />another run is active</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
