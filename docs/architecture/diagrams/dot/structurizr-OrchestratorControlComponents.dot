digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Component View: WORKSTATION1 Workflow Backup - Backup Orchestrator</font><br /><font point-size="24">C3: workflow-backup.sh control path for argument handling, locking, status, ledger, guard checks, publication, and error handling.</font>>

  28 [id=28,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured encrypted TrueNAS<br />dataset with current mirror<br />tree, manifests, SMB share,<br />restore checksum manifest,<br />refquota, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  29 [id=29,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured admin SSH and<br />middleware surface used for<br />ZFS properties, runtime-user<br />setup, snapshot tasks, SMB<br />share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    subgraph cluster_4 {
      margin=25
      label=<<font point-size="24"><br />Backup Orchestrator</font><br /><font point-size="19">[Container: Bash]</font>>
      labelloc=b
      color="#444444"
      fontcolor="#444444"
      fillcolor="#444444"

      13 [id=13,shape=rect, label=<<font point-size="34">NAS Status Publisher</font><br /><font point-size="19">[Component: Python + rsync over restricted SSH]</font><br /><br /><font point-size="24">Exports the run ledger to<br />JSON/SQLite snapshots and<br />rsyncs last-run/run-history<br />manifests to NAS through the<br />restricted runtime SSH<br />boundary.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      14 [id=14,shape=rect, label=<<font point-size="34">Integrity Manifest<br />Phase</font><br /><font point-size="19">[Component: Bash + restricted SSH]</font><br /><br /><font point-size="24">Runs the NAS-side checksum<br />helper after successful status<br />publication to write<br />restore-critical SHA-256<br />evidence.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      15 [id=15,shape=rect, label=<<font point-size="34">Error Trap</font><br /><font point-size="19">[Component: Bash ERR trap]</font><br /><br /><font point-size="24">Converts command failures into<br />failed status, ledger event,<br />best-effort NAS status sync,<br />and nonzero service exit.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      5 [id=5,shape=rect, label=<<font point-size="34">Argument Parser</font><br /><font point-size="19">[Component: Bash case parser]</font><br /><br /><font point-size="24">Handles --dry-run, --verbose,<br />--skip-windows, --skip-wsl,<br />and --quick-check-sqlite<br />flags.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      6 [id=6,shape=rect, label=<<font point-size="34">Lock and Run Identity</font><br /><font point-size="19">[Component: Bash + flock]</font><br /><br /><font point-size="24">Creates the local state/log<br />directories, acquires a flock<br />lock, generates run_id, and<br />skips concurrent runs<br />silently.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      7 [id=7,shape=rect, label=<<font point-size="34">Log and Last-Status<br />Writer</font><br /><font point-size="19">[Component: Bash + Python JSON helper]</font><br /><br /><font point-size="24">Prunes old local logs and<br />writes per-run logs plus<br />last-run.json with host,<br />status, duration, dry-run,<br />error, and log path.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      8 [id=8,shape=rect, label=<<font point-size="34">Run Ledger Adapter</font><br /><font point-size="19">[Component: record-run-ledger.py CLI]</font><br /><br /><font point-size="24">Appends<br />started/completed/failed/skipped<br />events with SQLite and Windows<br />manifest summaries.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
      9 [id=9,shape=rect, label=<<font point-size="34">Growth Guard Runner</font><br /><font point-size="19">[Component: Bash subprocess]</font><br /><br /><font point-size="24">Invokes<br />check-nas-growth-guard.sh<br />before and after writes and<br />fails closed on budget<br />violations.</font>>, style=filled, color="#22c55e", fillcolor="#f0fdf4", fontcolor="#111827"]
    }

    18 [id=18,shape=hexagon, label=<<font point-size="34">NAS Growth Guard</font><br /><font point-size="19">[Container: Bash + NAS sudo helper + zfs CLI]</font><br /><br /><font point-size="24">Read-only NAS-side ZFS budget<br />check that enforces<br />dataset-used, snapshot-held,<br />availability-dataset<br />free-space, and snapshot-count<br />limits before/after writes.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    19 [id=19,shape=hexagon, label=<<font point-size="34">NAS Integrity<br />Manifest Builder</font><br /><font point-size="19">[Container: Python + SHA-256]</font><br /><br /><font point-size="24">NAS-side helper that hashes<br />restore-critical current-tree<br />artifacts and writes<br />_manifests/integrity-manifest.json<br />for snapshot-preserved restore<br />verification.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    20 [id=20,shape=hexagon, label=<<font point-size="34">Restricted NAS<br />Runtime SSH Boundary</font><br /><font point-size="19">[Container: OpenSSH forced command + sudoers + ZFS refquota]</font><br /><br /><font point-size="24">Dedicated runtime NAS<br />user/key, pinned host-key<br />verification, forced-command<br />dispatcher, sudo allowlist,<br />and refquota-backed<br />current-tree write boundary.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
    25 [id=25,shape=cylinder, label=<<font point-size="34">Run Ledger and Local<br />State</font><br /><font point-size="19">[Container: SQLite + JSON + logs on WSL filesystem]</font><br /><br /><font point-size="24">Local status, pruned logs,<br />SQLite run ledger, exported<br />run-history JSON, SQLite<br />snapshot cache, and Windows<br />manifest cache under<br />~/.local/state/workstation-workflow-backup.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  }

  18 -> 29 [id=43, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads ZFS used,<br />availability,<br />usedbysnapshots, and<br />snapshot count from</font><br /><font point-size="19">[NAS-side helper + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
