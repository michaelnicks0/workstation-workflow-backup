digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">System Context View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">C1: WORKSTATION1 workflow backup system, local source surfaces, TrueNAS target/control plane, and failure-only Telegram notification.</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Michael</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole operator who installs,<br />verifies, and restores<br />WORKSTATION1 workflow backups.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  2 [id=2,shape=rect, label=<<font point-size="34">WORKSTATION1 Workflow<br />Backup</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Repo-owned backup automation<br />that mirrors workflow-critical<br />WSL and Windows artifacts to<br />TrueNAS through a restricted<br />runtime identity, preserves<br />rollback points with ZFS<br />snapshots, records run<br />history, writes restore<br />checksums, and alerts only on<br />failure.</font>>, style=filled, color="#16a34a", fillcolor="#dcfce7", fontcolor="#111827"]
  26 [id=26,shape=cylinder, label=<<font point-size="34">WSL Workflow Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Workflow-critical WSL paths:<br />~/repos, ~/.hermes, ~/.ssh,<br />systemd user config,<br />lifelog/browser-memory data,<br />and optional brain-code tree.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  27 [id=27,shape=cylinder, label=<<font point-size="34">Windows Workflow<br />Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Selected Windows user-profile<br />artifacts: Desktop, Documents,<br />Downloads, Windows<br />.ssh/.wslconfig, Terminal/VS<br />Code/PowerShell config, Chrome<br />profile metadata, and Startup<br />entries.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  28 [id=28,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured encrypted TrueNAS<br />dataset with current mirror<br />tree, manifests, SMB share,<br />restore checksum manifest,<br />refquota, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  29 [id=29,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured admin SSH and<br />middleware surface used for<br />ZFS properties, runtime-user<br />setup, snapshot tasks, SMB<br />share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  31 [id=31,shape=rect, label=<<font point-size="34">Telegram Bot API</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External API used only for<br />backup failure notifications.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  32 [id=32,shape=rect, label=<<font point-size="34">Operator Shell and<br />Restore Tools</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local shell, rsync, SSH,<br />Windows Previous Versions, and<br />README/runbook commands used<br />for verification and targeted<br />restores.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  1 -> 2 [id=33, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Installs, verifies, and<br />restores through</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  1 -> 32 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs backup, verification,<br />provisioning, and restore<br />commands from</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 2 [id=35, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Executes scripts and reads<br />documentation in</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 29 [id=37, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Lists snapshots and<br />inspects NAS state through</font><br /><font point-size="19">[admin SSH + zfs/midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 28 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Restores selected files<br />from .zfs/snapshot/current<br />paths</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 29 [id=44, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads ZFS used,<br />availability,<br />usedbysnapshots, and<br />snapshot count from</font><br /><font point-size="19">[NAS-side helper + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 26 [id=47, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads live SQLite<br />databases from</font><br /><font point-size="19">[sqlite3 backup API]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 28 [id=52, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Allows receiver-mode rsync<br />and mkdir only under<br />current tree</font><br /><font point-size="19">[forced command + rsync]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 27 [id=58, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Mirrors selected Windows<br />artifacts from</font><br /><font point-size="19">[robocopy.exe]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 31 [id=68, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Sends failure-only<br />notification to</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}