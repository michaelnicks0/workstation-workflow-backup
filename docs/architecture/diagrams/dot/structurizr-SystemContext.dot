digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">System Context View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">C1: WORKSTATION1 workflow backup system, local source surfaces, TrueNAS target/control plane, and failure-only Telegram notification.</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Michael</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole operator who installs,<br />verifies, and restores<br />WORKSTATION1 workflow backups.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  2 [id=2,shape=rect, label=<<font point-size="34">WORKSTATION1 Workflow<br />Backup</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Repo-owned backup automation<br />that mirrors workflow-critical<br />WSL and Windows artifacts to<br />TrueNAS, preserves rollback<br />points with ZFS snapshots,<br />records run history, and<br />alerts only on failure.</font>>, style=filled, color="#16a34a", fillcolor="#dcfce7", fontcolor="#111827"]
  22 [id=22,shape=cylinder, label=<<font point-size="34">WSL Workflow Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Workflow-critical WSL paths:<br />~/repos, ~/.hermes, ~/.ssh,<br />systemd user config,<br />lifelog/browser-memory data,<br />and optional brain-code tree.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  23 [id=23,shape=cylinder, label=<<font point-size="34">Windows Workflow<br />Sources</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Selected Windows user-profile<br />artifacts: Desktop, Documents,<br />Downloads, Windows<br />.ssh/.wslconfig, Terminal/VS<br />Code/PowerShell config, Chrome<br />profile metadata, and Startup<br />entries.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  24 [id=24,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Encrypted TrueNAS dataset<br />v1/ws1/wf with current mirror<br />tree, manifests, SMB share<br />ws1-wf, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  25 [id=25,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">root@10.99.98.221 management<br />surface used for ZFS<br />properties, snapshot tasks,<br />SMB share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  27 [id=27,shape=rect, label=<<font point-size="34">Telegram Bot API</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External API used only for<br />backup failure notifications.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  28 [id=28,shape=rect, label=<<font point-size="34">Operator Shell and<br />Restore Tools</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local shell, rsync, SSH,<br />Windows Previous Versions, and<br />README/runbook commands used<br />for verification and targeted<br />restores.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  1 -> 2 [id=29, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Installs, verifies, and<br />restores through</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  1 -> 28 [id=30, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs backup, verification,<br />provisioning, and restore<br />commands from</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 2 [id=31, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Executes scripts and reads<br />documentation in</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 25 [id=33, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Lists snapshots and<br />inspects NAS state through</font><br /><font point-size="19">[SSH + zfs/midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 24 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Restores selected files<br />from .zfs/snapshot/current<br />paths</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 25 [id=40, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads ZFS used, available,<br />usedbysnapshots, and<br />snapshot count from</font><br /><font point-size="19">[SSH + zfs]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 22 [id=43, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads live SQLite<br />databases from</font><br /><font point-size="19">[sqlite3 backup API]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 24 [id=47, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes current/wsl,<br />wsl-sqlite-snapshots, and<br />_manifests to</font><br /><font point-size="19">[SSH rsync + SSH cat]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 23 [id=50, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Mirrors selected Windows<br />artifacts from</font><br /><font point-size="19">[robocopy.exe]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  2 -> 27 [id=59, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Sends failure-only<br />notification to</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}