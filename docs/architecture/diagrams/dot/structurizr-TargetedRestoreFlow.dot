digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Dynamic View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">Targeted restore sequence from a ZFS snapshot; restores should stage first, then replace deliberately.</font>>

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    23 [id=23,shape=hexagon, label=<<font point-size="34">Backup Verifier</font><br /><font point-size="19">[Container: Bash + systemctl + SSH]</font><br /><br /><font point-size="24">Operational verification<br />script that checks the local<br />timer, last status, run<br />ledger, growth guard, NAS<br />dataset, snapshots, manifests,<br />integrity summary, snapshot<br />tasks, and retired cron jobs.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
  }

  1 [id=1,shape=rect, label=<<font point-size="34">Michael</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole operator who installs,<br />verifies, and restores<br />WORKSTATION1 workflow backups.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  28 [id=28,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured encrypted TrueNAS<br />dataset with current mirror<br />tree, manifests, SMB share,<br />restore checksum manifest,<br />refquota, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  29 [id=29,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Configured admin SSH and<br />middleware surface used for<br />ZFS properties, runtime-user<br />setup, snapshot tasks, SMB<br />share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  32 [id=32,shape=rect, label=<<font point-size="34">Operator Shell and<br />Restore Tools</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local shell, rsync, SSH,<br />Windows Previous Versions, and<br />README/runbook commands used<br />for verification and targeted<br />restores.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  1 -> 32 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">1. Select snapshot before<br />loss/corruption</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 29 [id=37, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">2. List snapshots under<br />configured backup dataset</font><br /><font point-size="19">[admin SSH + zfs/midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 28 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">3. Copy selected<br />.zfs/snapshot/.../current<br />path to restore candidate</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 28 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">4. Read snapshot<br />integrity-manifest.json<br />for checksum comparison</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  32 -> 23 [id=36, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">5. Run verify-backup.sh<br />after timer resumes</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}