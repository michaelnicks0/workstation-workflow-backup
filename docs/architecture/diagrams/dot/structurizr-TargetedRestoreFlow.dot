digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Dynamic View: WORKSTATION1 Workflow Backup</font><br /><font point-size="24">Targeted restore sequence from a ZFS snapshot; restores should stage first, then replace deliberately.</font>>

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />WORKSTATION1 Workflow Backup</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    19 [id=19,shape=hexagon, label=<<font point-size="34">Backup Verifier</font><br /><font point-size="19">[Container: Bash + systemctl + SSH]</font><br /><br /><font point-size="24">Operational verification<br />script that checks the local<br />timer, last status, run<br />ledger, growth guard, NAS<br />dataset, snapshots, manifests,<br />snapshot tasks, and retired<br />cron jobs.</font>>, style=filled, color="#0891b2", fillcolor="#ecfeff", fontcolor="#111827"]
  }

  1 [id=1,shape=rect, label=<<font point-size="34">Michael</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole operator who installs,<br />verifies, and restores<br />WORKSTATION1 workflow backups.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  24 [id=24,shape=cylinder, label=<<font point-size="34">TrueNAS Backup<br />Dataset</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Encrypted TrueNAS dataset<br />v1/ws1/wf with current mirror<br />tree, manifests, SMB share<br />ws1-wf, and ZFS snapshot<br />history.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  25 [id=25,shape=rect, label=<<font point-size="34">TrueNAS Middleware<br />and ZFS Control Plane</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">root@10.99.98.221 management<br />surface used for ZFS<br />properties, snapshot tasks,<br />SMB share configuration, and<br />verification.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  28 [id=28,shape=rect, label=<<font point-size="34">Operator Shell and<br />Restore Tools</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local shell, rsync, SSH,<br />Windows Previous Versions, and<br />README/runbook commands used<br />for verification and targeted<br />restores.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  1 -> 28 [id=30, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">1. Select snapshot before<br />loss/corruption</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 25 [id=33, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">2. List snapshots under<br />v1/ws1/wf</font><br /><font point-size="19">[SSH + zfs/midclt]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 24 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">3. Copy selected<br />.zfs/snapshot/.../current<br />path to restore candidate</font><br /><font point-size="19">[SSH rsync or SMB Previous Versions]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  28 -> 19 [id=32, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">4. Run verify-backup.sh<br />after timer resumes</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}